# Required core settings
# - DATABASE_URL and SESSION_SECRET are required for startup.
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw_dev
SESSION_SECRET=replace-with-random-64-char-secret

# Runtime mode
NODE_ENV=development
PORT=4000

# Queue / dedupe infrastructure
# - Set REDIS_URL for strongest reliability.
# - If omitted, API uses fallback in-process behavior and standalone worker cannot run.
REDIS_URL=redis://localhost:6379

# Admin seed convenience (optional)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=replace-with-strong-password

# OpenRouter (required for AI responses and model routing)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Telegram integration (optional; both needed for webhook mode)
TELEGRAM_BOT_TOKEN=123456:ABCDEF...
TELEGRAM_WEBHOOK_SECRET=replace-with-min-16-char-secret
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Email integration (optional)
INBOUND_EMAIL_WEBHOOK_SECRET=replace-with-min-16-char-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=OpenClaw <noreply@example.com>

# GHL CRM sub-agent (optional)
GHL_API_BASE_URL=https://rest.gohighlevel.com/v1
GHL_API_TOKEN=replace-with-ghl-token

# Google Sheets bookkeeping export (optional)
# - GOOGLE_SERVICE_ACCOUNT_JSON must contain the FULL service account JSON
#   including "type", "project_id", "private_key", "client_email", and all other fields.
#   Get this from Google Cloud Console > IAM > Service Accounts > Keys > Create Key (JSON).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com"}
GOOGLE_SHEETS_BOOKKEEPING_SPREADSHEET_ID=your-spreadsheet-id

# App URLs
APP_BASE_URL=http://localhost:4000
ADMIN_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Hosting / frontend dev
# - Render injects RENDER_EXTERNAL_URL automatically in production.
RENDER_EXTERNAL_URL=https://your-api.onrender.com
# - Used by the admin Vite dev server only.
VITE_DEV_PROXY_TARGET=http://localhost:4000

# Worker and request tuning
WORKER_CONCURRENCY=5
REQUEST_TIMEOUT_MS=30000
MAX_PAYLOAD_SIZE=2mb
