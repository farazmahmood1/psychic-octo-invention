# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/openclaw_dev
REDIS_URL=redis://localhost:6379

# ── Auth / Sessions ──────────────────────────────────
SESSION_SECRET=change-me-to-a-random-64-char-string
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me-strong-password

# ── AI / Model Routing ───────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Telegram ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_SECRET=change-me-webhook-secret

# ── Email ────────────────────────────────────────────
INBOUND_EMAIL_WEBHOOK_SECRET=change-me-inbound-secret
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=change-me-smtp-password
SMTP_FROM=OpenClaw <noreply@example.com>

# ── GHL CRM ─────────────────────────────────────────
GHL_API_BASE_URL=https://rest.gohighlevel.com/v1
GHL_API_TOKEN=change-me-ghl-token

# ── Google Sheets ────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEETS_BOOKKEEPING_SPREADSHEET_ID=your-spreadsheet-id

# ── App URLs ─────────────────────────────────────────
APP_BASE_URL=http://localhost:4000
ADMIN_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# ── Worker / Performance ────────────────────────────
WORKER_CONCURRENCY=5
REQUEST_TIMEOUT_MS=30000
MAX_PAYLOAD_SIZE=2mb

# ── Environment ──────────────────────────────────────
NODE_ENV=development
