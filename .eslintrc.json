{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:@typescript-eslint/recommended-requiring-type-checking",
    "prettier"
  ],
  "rules": {
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/no-floating-promises": "error",
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  },
  "overrides": [
    {
      "files": ["apps/admin/**/*.{ts,tsx}"],
      "plugins": ["react", "react-hooks"],
      "extends": [
        "plugin:react/recommended",
        "plugin:react/jsx-runtime",
        "plugin:react-hooks/recommended"
      ],
      "settings": {
        "react": { "version": "detect" }
      },
      "parserOptions": {
        "ecmaFeatures": { "jsx": true },
        "project": "./apps/admin/tsconfig.eslint.json"
      }
    },
    {
      "files": ["apps/api/**/*.ts"],
      "parserOptions": {
        "project": "./apps/api/tsconfig.eslint.json"
      }
    },
    {
      "files": ["packages/config/**/*.ts"],
      "parserOptions": {
        "project": "./packages/config/tsconfig.json"
      }
    },
    {
      "files": ["packages/shared/**/*.ts"],
      "parserOptions": {
        "project": "./packages/shared/tsconfig.eslint.json"
      }
    },
    {
      "files": ["e2e/**/*.ts", "playwright.config.ts", "scripts/**/*.ts"],
      "parserOptions": {
        "project": "./tsconfig.e2e.json"
      }
    }
  ],
  "ignorePatterns": ["dist", "build", "node_modules", "*.js"]
}
